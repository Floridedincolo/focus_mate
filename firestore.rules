rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ───────────────────────────────────────────────────────────
    match /users/{uid} {
      // Anyone authenticated can read public profiles (needed for search).
      allow read: if request.auth != null;
      // Only the owner can write their own profile.
      allow write: if request.auth != null && request.auth.uid == uid;

      // Tasks sub-collection
      // Read: owner + any authenticated user (for meeting suggestions).
      //   Schedule data is not sensitive; friendship verification happens
      //   in the app layer (FriendRepositoryImpl).
      // Write: owner only.
      match /tasks/{taskId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
      match /tasks/{taskId}/completions/{dateId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Friendships ─────────────────────────────────────────────────────
    match /friendships/{friendshipId} {
      // Single-document reads: both parties can read.
      allow get: if request.auth != null &&
        (request.auth.uid == resource.data.requesterId ||
         request.auth.uid == resource.data.receiverId);

      // List/query reads: Firestore cannot evaluate resource.data for
      // collection queries. The app queries with .where('requesterId'/'receiverId')
      // constraints, so we allow any authenticated user to list.
      // The actual filtering is done by the query constraints.
      allow list: if request.auth != null;

      // Only the requester can create; status must start as "pending".
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.requesterId &&
        request.resource.data.status == 'pending';

      // Only the receiver can update (accept / decline).
      // Only status and updatedAt may change.
      allow update: if request.auth != null &&
        request.auth.uid == resource.data.receiverId &&
        request.resource.data.requesterId == resource.data.requesterId &&
        request.resource.data.receiverId == resource.data.receiverId &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.status in ['accepted', 'declined'];

      // No deletes — we soft-delete via status = "declined".
      allow delete: if false;
    }

    // ── Meeting Proposals ───────────────────────────────────────────────
    match /meetingProposals/{proposalId} {
      // Single-document reads: only group members can read.
      allow get: if request.auth != null &&
        request.auth.uid in resource.data.groupMemberUids;

      // List/query reads: Firestore cannot evaluate resource.data for
      // collection queries. The app queries with array-contains constraints,
      // so we allow any authenticated user to list.
      allow list: if request.auth != null;

      // Any authenticated user can create (they must be in the group).
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.groupMemberUids;

      // Group members can update (e.g., confirm location).
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.groupMemberUids;

      allow delete: if false;
    }
  }
}

